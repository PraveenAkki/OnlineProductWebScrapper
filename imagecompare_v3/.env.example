# ============================================================
# ImageCompare — Environment Variables
# ============================================================
# SETUP:
#   1. Copy this file and rename it to: .env
#   2. Fill in your API keys below
#   3. Place .env at: D:\imagecompare\.env  (next to manage.py)
#   4. NEVER commit .env to git
# ============================================================

# ── Phase 4B: Google Lens via SerpAPI ────────────────────────
# Get free key at: https://serpapi.com/
# Free tier: 100 searches/month
# Paid tier: $50/month for 5000 searches
SERPAPI_KEY=your_serpapi_key_here

# ── Future use ────────────────────────────────────────────────
# GOOGLE_API_KEY=
# AMAZON_AFFILIATE_KEY=
